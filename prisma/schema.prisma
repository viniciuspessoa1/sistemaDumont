generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Alert {
  id        String   @id @default(uuid())
  os        String
  cliente   String
  tipo      String
  mensagem  String
  email     String
  lido      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([os, tipo])
}

model FollowUp {
  id        String   @id @default(uuid())
  os        String
  tipo      String
  prazo     DateTime
  resolvido Boolean @default(false)
}